# SentinelANPR AI — Environment variables
# Copy this file to backend/.env and set your values.

SENTINEL_ENV=development
SENTINEL_APP_NAME=sentinel-anpr-ai
SENTINEL_LOG_LEVEL=INFO
SENTINEL_DATABASE_URL=sqlite:///./data/sentinel_anpr.db
SENTINEL_API_HOST=0.0.0.0
SENTINEL_API_PORT=8080
SENTINEL_AUTH_JWT_SECRET=dev-only-change-in-production
SENTINEL_AUTH_JWT_ISSUER=sentinel-anpr-ai
SENTINEL_AUTH_ACCESS_TOKEN_TTL_SECONDS=900
SENTINEL_AUTH_REFRESH_TOKEN_TTL_SECONDS=604800
SENTINEL_UPLOAD_STORAGE_DIR=data/uploads
SENTINEL_REPORT_STORAGE_DIR=data/reports

# Comma-separated browser origins for split frontend/backend deploys.
# Example: https://sentinel-anpr.onrender.com,https://www.example.com
SENTINEL_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Vision provider for the verification workflow:
#   "gemini" -> multimodal Gemini Vision analysis (requires GEMINI_API_KEY below)
#   "stub"   -> deterministic hardcoded plate (tests only; do not use for real uploads)
# OPENAI_API_KEY is not used and is never validated.
SENTINEL_VISION_PROVIDER=gemini
SENTINEL_GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
