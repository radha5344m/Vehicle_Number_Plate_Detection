# Frontend environment (copy to .env.local)
#
# Local dev: leave empty — Vite proxies /v1 -> http://127.0.0.1:8080
# Split production deploy: set to your backend URL (no trailing slash), e.g.:
#   VITE_API_BASE_URL=https://sentinel-anpr-api.onrender.com
# Combined deploy (API serves the SPA): leave empty
VITE_API_BASE_URL=
VITE_APP_ENV=development
